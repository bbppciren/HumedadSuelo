};

exports.onChangeDownloadYear = function(c, links, selectedYear, s) {
  links.forEach(function(link, i) {
    // Concatenación de strings para el nombre del archivo
    var url = link.getDownloadURL({ 
      //name: 'SM' + selectedYear + 'Valparaiso_' + i,
      name: 'HS_anual.tif',
      scale: 1000,
      filePerBand: false,
      format: 'GeoTIFF'
    });
    
    // Asigna el URL y estilo a los labels correspondientes
    c.downloadYear['label' + (i + 1)].setUrl(url);
    c.downloadYear['label' + (i + 1)].style().set(s.ableLabel);
  });
  c.downloadYear.panel.style().set('shown', true);
};

